# ─────────────────────────────────────────────────────────────────────────────
# Taibu AI OS Eesti — keskkonnamuutujad (credentials)
#
# 1. Kopeeri see fail nimega .env  →  cp .env.example .env
# 2. Täida ainult need read, mida päriselt kasutad. Ülejäänud jäta kommentaariks.
# 3. .env on .gitignore-s — seda EI laeta kunagi GitHubi. Hoia võtmeid salajas.
#
# Iga tööriista juhend asub references/{tööriist}-api.md failis.
# ─────────────────────────────────────────────────────────────────────────────


# ── RAAMATUPIDAMINE & ARVELDUS ───────────────────────────────────────────────
# Merit Aktiva — Eesti populaarseim raamatupidamistarkvara
# Hangi: Merit Aktiva → Seaded → API seaded (admin genereerib ID + Key)
# Juhend: references/merit-aktiva-api.md
MERIT_API_ID=
MERIT_API_KEY=
# Baas-URL: EE = https://aktiva.merit.ee/api/v1  |  PL = https://aktiva.meritsolutions.pl/api/v1
MERIT_BASE_URL=https://aktiva.merit.ee/api/v1


# ── MAKSED ───────────────────────────────────────────────────────────────────
# Montonio — pangalink, kaardimaksed, järelmaks (EE/LV/LT/PL)
# Hangi: Montonio Partner System → Stores → sinu pood → API Keys
# Juhend: references/montonio-api.md
MONTONIO_ACCESS_KEY=
MONTONIO_SECRET_KEY=
# Sandbox testimiseks (eraldi võtmepaar):
MONTONIO_SANDBOX_ACCESS_KEY=
MONTONIO_SANDBOX_SECRET_KEY=
# Keskkond: production = https://stargate.montonio.com  |  sandbox = https://sandbox-stargate.montonio.com
MONTONIO_BASE_URL=https://stargate.montonio.com


# ── CRM / MÜÜK ───────────────────────────────────────────────────────────────
# Pipedrive — Eestis asutatud CRM
# Hangi: Pipedrive → avatar → Personal Preferences → API
# Juhend: references/pipedrive-api.md
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=          # nt minufirma  (minufirma.pipedrive.com)


# ── REKLAAM / TURUNDUS ───────────────────────────────────────────────────────
# Meta (Facebook / Instagram) Marketing API — domineeriv kanal Eesti SMB-des
# Hangi: developers.facebook.com → sinu äpp → Marketing API
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=               # vorming: act_1234567890
META_PIXEL_ID=
META_APP_ID=
META_APP_SECRET=

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=


# ── ANALÜÜTIKA / JÄLGIMINE ───────────────────────────────────────────────────
# Google Tag Manager (Tag Manager API v2) — teenusekonto JSON failina
# Fail ise on .gitignore-s (*-service-account.json)
GTM_SERVICE_ACCOUNT_JSON=gtm-service-account.json
GTM_ACCOUNT_ID=
GTM_CONTAINER_ID=                 # nt GTM-XXXXXXX
# Google Analytics 4
GA4_MEASUREMENT_ID=               # nt G-XXXXXXXXXX
GA4_API_SECRET=


# ── AUTOMATISEERIMINE ────────────────────────────────────────────────────────
# Make.com (Integromat) — no-code automaatika, seob rakendusi
# Vajalik AINULT kui juhid Make'i API kaudu. Tavaliselt impordid blueprinte käsitsi.
# Hangi: Make → Profile → API → Generate token
# Juhend: references/make-com.md  |  Oskus: /make-blueprint
MAKE_API_TOKEN=
MAKE_ZONE=eu2                     # eu1 / eu2 / us1 — vaata oma Make URL-i
MAKE_TEAM_ID=


# ── E-ARVELDUS & RIIK (Eesti) ────────────────────────────────────────────────
# E-arve operaator (Omniva / Telema / Unifiedpost-Fitek) — vajadusel
EINVOICE_OPERATOR=
EINVOICE_API_KEY=
# Ettevõtte registriandmed
COMPANY_REG_CODE=                 # registrikood (8 numbrit)
COMPANY_VAT_NUMBER=               # KMKR number, nt EE123456789
# Äriregister (e-Business Register) avaandmete API — vajadusel
ARIREGISTER_API_USER=
ARIREGISTER_API_KEY=


# ── E-MAIL / TEAVITUSED ──────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=                     # kuhu Taibu AI OS saadab kokkuvõtteid


# ── AI MUDELID ───────────────────────────────────────────────────────────────
# Claude Code kasutab oma autentimist; need on vajalikud ainult oma skriptidele.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                   # valikuline
